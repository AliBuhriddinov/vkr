# Auto-detect text files, store with LF in the repository.
* text=auto eol=lf

# Windows-only scripts must keep CRLF.
*.bat   text eol=crlf
*.cmd   text eol=crlf
*.ps1   text eol=crlf

# Explicit text formats (LF).
*.ts    text eol=lf
*.tsx   text eol=lf
*.js    text eol=lf
*.mjs   text eol=lf
*.cjs   text eol=lf
*.json  text eol=lf
*.css   text eol=lf
*.md    text eol=lf
*.yml   text eol=lf
*.yaml  text eol=lf
*.prisma text eol=lf
*.env*  text eol=lf
Dockerfile text eol=lf

# Binary formats — Git should never touch them.
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.ico   binary
*.webp  binary
*.woff  binary
*.woff2 binary
*.ttf   binary
*.eot   binary
*.pdf   binary
*.zip   binary
*.tar   binary
*.gz    binary

# SVG treated as text (so diffs are readable).
*.svg   text eol=lf
